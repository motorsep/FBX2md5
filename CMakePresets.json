{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 16,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "win-x64-release",
            "displayName": "Windows x64 Release",
            "description": "Visual Studio 2022, x64, Release, static FBX SDK",
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FBX_STATIC": "ON"
            }
        },
        {
            "name": "win-x64-debug",
            "displayName": "Windows x64 Debug",
            "description": "Visual Studio 2022, x64, Debug, static FBX SDK",
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "FBX_STATIC": "ON"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux x64 Release",
            "description": "GCC/Clang, x64, Release, static FBX SDK",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "FBX_STATIC": "ON"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Linux x64 Debug",
            "description": "GCC/Clang, x64, Debug, static FBX SDK",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "FBX_STATIC": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "win-release",
            "configurePreset": "win-x64-release",
            "configuration": "Release"
        },
        {
            "name": "win-debug",
            "configurePreset": "win-x64-debug",
            "configuration": "Debug"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release"
        },
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug"
        }
    ]
}
